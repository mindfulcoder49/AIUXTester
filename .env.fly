# Non-secret runtime config
PORT=8080
DB_BACKEND=mariadb
DATABASE_URL=mysql://aiuxtester:CHANGE_ME@db-internal.example:3306/aiuxtester
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
QUEUE_MODE=redis
REDIS_URL=redis://127.0.0.1:6379/0

# App auth/admin config
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me

# Model provider keys (set as Fly secrets in production)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
