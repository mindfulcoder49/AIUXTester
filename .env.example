# Core app settings
# sqlite mode:
DB_BACKEND=sqlite
DATABASE_URL=
DATABASE_PATH=./aiuxtester.db
# mariadb mode example:
# DB_BACKEND=mariadb
# DATABASE_URL=mysql://aiuxtester:aiuxtester@127.0.0.1:3306/aiuxtester
QUEUE_MODE=inline
REDIS_URL=redis://127.0.0.1:6379/0
JWT_SECRET=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM provider API keys
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional admin bootstrap account (created at startup if not present)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# Optional E2E test settings (for real-model integration runs)
E2E_OPENAI_MODEL=gpt-5-mini
E2E_TEST_START_URL=https://example.com
E2E_TEST_GOAL=Try to use this website
E2E_MAX_STEPS=15
E2E_MODE=desktop
