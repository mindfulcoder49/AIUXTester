# Non-secret runtime config
PORT=8080
DB_BACKEND=mariadb
DATABASE_URL=mysql://aiuxtester:change-me@aiuxtester-db.internal:3306/aiuxtester
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
QUEUE_MODE=redis
REDIS_URL=redis://:change-me@aiuxtester-redis.internal:6379/0

# Redis app secrets (app: aiuxtester-redis)
REDIS_PASSWORD=change-me

# MariaDB app secrets (app: aiuxtester-db)
MARIADB_ROOT_PASSWORD=change-me
MARIADB_PASSWORD=change-me

# App auth/admin config
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me

# Model provider keys (set as Fly secrets in production)
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
